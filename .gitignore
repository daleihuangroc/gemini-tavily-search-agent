# --- Secrets & Environment Variables ---
# Never commit your API keys!
.env

# --- Python & Virtual Environments ---
# Ignore the local virtual environment folder
.venv/
__pycache__/
*.py[cod]
*$py.class

# --- IDEs & Editors ---
# PyCharm / IntelliJ
.idea/

# VS Code
.vscode/
